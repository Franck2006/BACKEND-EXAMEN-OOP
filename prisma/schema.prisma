generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id    String @id
  name  String
  email String @unique



}

model Word {
  id          String   @id
  word        String
  meaning     String
  example     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
